PORT=8000
MONGODB_URI=mongodb://localhost:27017/ddd_task
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=post-service
KAFKA_GROUP_ID=post-group

# 📧 Optional: Real SMTP Configuration (Gmail, Mailgun, Sendgrid, Mailtrap, etc.)
# Note: If left blank, Nodemailer automatically provisions a temporary Ethereal test inbox
# and prints a clickable web link in the console logs where you can see the real sent email!
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="DDD Microservice <no-reply@dddtask.com>"

# 🔔 Optional: Discord Webhook URL for Real-Time Screen Push Notifications (Mobile & Desktop!)
# Create a free Discord channel -> Channel Settings -> Integrations -> Webhooks -> Copy Webhook URL.
# If you don't wish to use it, set to 'skip'.
DISCORD_WEBHOOK_URL=skip
